import cv2
import numpy as np
import json
from datetime import datetime


class BleedingDetectorNoPyTorch:
    def __init__(self):
        # Stores red area values over time
        self.red_area_history = []

        # Alert rule: >30% increase over 2 seconds
        self.increase_threshold = 0.30

        # Minimum red area ratio to avoid tiny false positives
        self.min_red_area_ratio = 0.01

    def detect_red_area(self, frame):
        """
        1) Convert frame to HSV color space.
        2) Define red color range using two HSV ranges.
        3) Compute red area.
        """

        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)

        # Red range 1: lower hue reds
        lower_red_1 = np.array([0, 80, 80])
        upper_red_1 = np.array([10, 255, 255])

        # Red range 2: upper hue reds
        lower_red_2 = np.array([170, 80, 80])
        upper_red_2 = np.array([180, 255, 255])

        mask1 = cv2.inRange(hsv, lower_red_1, upper_red_1)
        mask2 = cv2.inRange(hsv, lower_red_2, upper_red_2)

        red_mask = mask1 + mask2

        # Clean the mask to reduce noise
        kernel = np.ones((5, 5), np.uint8)
        red_mask = cv2.morphologyEx(red_mask, cv2.MORPH_OPEN, kernel)
        red_mask = cv2.morphologyEx(red_mask, cv2.MORPH_CLOSE, kernel)

        red_area_pixels = np.sum(red_mask > 0)
        total_pixels = frame.shape[0] * frame.shape[1]
        red_area_ratio = red_area_pixels / total_pixels

        return red_mask, red_area_pixels, red_area_ratio

    def compute_change_over_time(self, current_red_area):
        """
        4) Compute change in red area over time.
        Since we process at 1 fps, 2 seconds = 2 frames.
        """

        self.red_area_history.append(current_red_area)

        percent_change = 0.0

        # Need at least 3 sampled frames to compare current frame to 2 seconds ago
        if len(self.red_area_history) >= 3:
            red_area_2_seconds_ago = self.red_area_history[-3]

            if red_area_2_seconds_ago > 0:
                percent_change = (
                    current_red_area - red_area_2_seconds_ago
                ) / red_area_2_seconds_ago

        return percent_change

